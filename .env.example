# Backend secrets/configuration. Copy this to .env for local testing.
# Never commit a real .env file.

# OpenRouter API key stays on backend only. Do not put it in app.js or index.html.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Choose a free OpenRouter model if needed.
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# CORS origin for deployed backend. Replace with your GitHub Pages URL in Vercel.
ALLOWED_ORIGIN=https://YOUR-GITHUB-USERNAME.github.io

# Optional public app URL used as OpenRouter HTTP-Referer.
APP_PUBLIC_URL=https://YOUR-GITHUB-USERNAME.github.io/YOUR-REPO-NAME/

# Local server port for npm start.
PORT=8080
